<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Backgrounds -->
    <Color x:Key="AppBackground">#0D1117</Color>
    <Color x:Key="SurfaceBackground">#161B22</Color>
    <Color x:Key="SurfaceElevated">#1C2333</Color>
    <Color x:Key="SurfaceBorder">#30363D</Color>

    <!-- Accents -->
    <Color x:Key="AccentTeal">#00C9A7</Color>
    <Color x:Key="AccentAmber">#F59E0B</Color>
    <Color x:Key="AccentRose">#F43F5E</Color>
    <Color x:Key="AccentGreen">#4ADE80</Color>
    <Color x:Key="AccentBlue">#3B82F6</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#E2E8F0</Color>
    <Color x:Key="TextSecondary">#94A3B8</Color>
    <Color x:Key="TextMuted">#64748B</Color>
    <Color x:Key="TextOnAccent">#0D1117</Color>

    <!-- Legacy keys kept for compatibility -->
    <Color x:Key="Primary">#00C9A7</Color>
    <Color x:Key="PrimaryDark">#00C9A7</Color>
    <Color x:Key="PrimaryDarkText">#0D1117</Color>
    <Color x:Key="Secondary">#F59E0B</Color>
    <Color x:Key="SecondaryDarkText">#0D1117</Color>
    <Color x:Key="Tertiary">#F43F5E</Color>
    <Color x:Key="White">#E2E8F0</Color>
    <Color x:Key="Black">#0D1117</Color>
    <Color x:Key="Magenta">#00C9A7</Color>
    <Color x:Key="MidnightBlue">#0D1117</Color>
    <Color x:Key="OffBlack">#0D1117</Color>
    <Color x:Key="Gray100">#E2E8F0</Color>
    <Color x:Key="Gray200">#CBD5E1</Color>
    <Color x:Key="Gray300">#94A3B8</Color>
    <Color x:Key="Gray400">#64748B</Color>
    <Color x:Key="Gray500">#475569</Color>
    <Color x:Key="Gray600">#334155</Color>
    <Color x:Key="Gray900">#1E293B</Color>
    <Color x:Key="Gray950">#0D1117</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource AccentTeal}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource AccentAmber}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource AccentRose}"/>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceBackground}"/>
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="{StaticResource SurfaceBorder}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource AppBackground}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource AppBackground}"/>
</ResourceDictionary>
