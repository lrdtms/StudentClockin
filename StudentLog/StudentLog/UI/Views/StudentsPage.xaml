<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:StudentLog.UI.ViewModels"
             xmlns:models="clr-namespace:StudentLog.Core.Models"
             x:Class="StudentLog.UI.Views.StudentsPage"
             x:DataType="viewModels:StudentsViewModel"
             Title="Students">

    <AbsoluteLayout>

        <!-- Main scrollable content -->
        <ScrollView AbsoluteLayout.LayoutBounds="0,0,1,1" AbsoluteLayout.LayoutFlags="All">
            <VerticalStackLayout Padding="16" Spacing="0">

                <Label Text="Add Student" Style="{StaticResource SectionHeader}"/>

                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="10">
                        <Picker Title="Select cohort"
                                ItemsSource="{Binding Cohorts}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedCohort}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Entry Grid.Column="0" Placeholder="First name" Text="{Binding Name}" />
                            <Entry Grid.Column="1" Placeholder="Surname" Text="{Binding Surname}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry Grid.Column="0" Placeholder="NFC UID" Text="{Binding Uid}" />
                            <Button Grid.Column="1" Text="SCAN" Command="{Binding ScanUidCommand}" Style="{StaticResource SecondaryButton}" />
                        </Grid>
                        <Button Text="ADD STUDENT" Command="{Binding AddStudentCommand}" HorizontalOptions="Start"/>
                        <Label Text="{Binding StatusMessage}" Style="{StaticResource MutedLabel}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="All Students" Style="{StaticResource SectionHeader}"/>

                <CollectionView ItemsSource="{Binding AllStudentsForCohort}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Student">
                            <Border Style="{StaticResource Card}">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">

                                    <StackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                        <StackLayout Orientation="Horizontal" Spacing="6">
                                            <Label Text="{Binding Name}" FontFamily="OpenSansSemibold" FontSize="14" />
                                            <Label Text="{Binding Surname}" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                                        </StackLayout>
                                        <Label Text="{Binding UID}" Style="{StaticResource MutedLabel}" />
                                    </StackLayout>

                                    <Button Grid.Column="1"
                                            Text="HISTORY"
                                            Style="{StaticResource SuccessButton}"
                                            FontSize="11" Padding="10,6" MinimumHeightRequest="32"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewHistoryCommand}"
                                            CommandParameter="{Binding .}" />

                                    <Button Grid.Column="2"
                                            Text="EDIT"
                                            Style="{StaticResource SecondaryButton}"
                                            FontSize="11" Padding="10,6" MinimumHeightRequest="32"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditStudentCommand}"
                                            CommandParameter="{Binding .}" />

                                    <Button Grid.Column="3"
                                            Text="DEL"
                                            Style="{StaticResource DangerButton}"
                                            FontSize="11" Padding="10,6" MinimumHeightRequest="32"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteStudentCommand}"
                                            CommandParameter="{Binding .}" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Modal dimming overlay -->
        <BoxView IsVisible="{Binding IsEditingStudent}"
                 Color="{StaticResource AppBackground}"
                 Opacity="0.75"
                 AbsoluteLayout.LayoutBounds="0,0,1,1"
                 AbsoluteLayout.LayoutFlags="All" />

        <!-- Edit Student modal — centred, fixed size -->
        <Border IsVisible="{Binding IsEditingStudent}"
                Style="{StaticResource AccentCard}"
                AbsoluteLayout.LayoutBounds="0.5,0.4,440,300"
                AbsoluteLayout.LayoutFlags="PositionProportional">
            <VerticalStackLayout Spacing="12">
                <Label Text="EDIT STUDENT" Style="{StaticResource SectionHeader}" Margin="0"/>
                <Entry Placeholder="First name" Text="{Binding EditStudentName}" />
                <Entry Placeholder="Surname" Text="{Binding EditStudentSurname}" />
                <Entry Placeholder="NFC UID" Text="{Binding EditStudentUid}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
                    <Button Grid.Column="0" Text="SAVE" Command="{Binding SaveEditedStudentCommand}" />
                    <Button Grid.Column="1" Text="CANCEL" Command="{Binding CancelEditCommand}" Style="{StaticResource SecondaryButton}" />
                </Grid>
            </VerticalStackLayout>
        </Border>

    </AbsoluteLayout>
</ContentPage>
