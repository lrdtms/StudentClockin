<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:StudentLog.UI.ViewModels"
             xmlns:models="clr-namespace:StudentLog.Core.Models"
             x:Class="StudentLog.UI.Views.StudentHistoryPage"
             x:DataType="viewModels:StudentHistoryViewModel"
             Title="Student History">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16" RowSpacing="0">

        <!-- Student identity card -->
        <Border Grid.Row="0" Style="{StaticResource AccentCard}" Margin="0,8,0,0">
            <Grid ColumnDefinitions="*" ColumnSpacing="16">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <StackLayout Orientation="Horizontal" Spacing="8">
                        <Label Text="{Binding Student.Name}" FontFamily="OpenSansSemibold" FontSize="20" />
                        <Label Text="{Binding Student.Surname}" FontSize="20" TextColor="{StaticResource TextSecondary}" />
                    </StackLayout>
                    <Label Text="{Binding Student.UID}" Style="{StaticResource MutedLabel}" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Label Grid.Row="1" Text="Attendance History" Style="{StaticResource SectionHeader}"/>

        <!-- Empty state -->
        <Label Grid.Row="2"
               Text="No attendance records found."
               Style="{StaticResource MutedLabel}"
               IsVisible="{Binding IsHistoryEmpty}"
               HorizontalTextAlignment="Center"
               VerticalOptions="Center" />

        <!-- History list -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding AttendanceHistory}" IsVisible="{Binding IsHistoryNotEmpty}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AttendanceRecord">
                    <Border Style="{StaticResource Card}">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">

                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="SIGN IN" Style="{StaticResource MutedLabel}" />
                                <Label Text="{Binding FormattedSignInTime}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="{StaticResource AccentTeal}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="SIGN OUT" Style="{StaticResource MutedLabel}" />
                                <Label Text="{Binding FormattedSignOutTime}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" Spacing="4">
                                <Label Text="DURATION" Style="{StaticResource MutedLabel}" />
                                <Label Text="{Binding FormattedDuration}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="{StaticResource AccentGreen}" />
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom actions -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,12,0,8">
            <Button Grid.Column="0" Text="BACK TO STUDENTS" Command="{Binding BackCommand}" Style="{StaticResource SecondaryButton}" />
            <Button Grid.Column="1" Text="DOWNLOAD CSV" Command="{Binding ExportCsvCommand}" Style="{StaticResource SuccessButton}" />
        </Grid>

    </Grid>
</ContentPage>
