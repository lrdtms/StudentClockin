<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:StudentLog.UI.ViewModels"
             xmlns:models="clr-namespace:StudentLog.Core.Models"
             x:Class="StudentLog.UI.Views.CohortsPage"
             x:DataType="viewModels:CohortsViewModel"
             Title="Cohorts">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="0">

        <!-- Top management panel -->
        <VerticalStackLayout Grid.Row="0" Spacing="0">

            <Label Text="Cohort Management" Style="{StaticResource SectionHeader}"/>

            <!-- Add cohort inline -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,0,0,8">
                <Entry Grid.Column="0" Placeholder="New cohort name..." Text="{Binding NewCohortName}" />
                <Button Grid.Column="1" Text="ADD" Command="{Binding AddCohortCommand}" />
            </Grid>

            <!-- Cohort list — capped height so attendance list always gets space -->
            <CollectionView ItemsSource="{Binding Cohorts}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedCohort}"
                            MaximumHeightRequest="180">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Cohort">
                        <Border Style="{StaticResource Card}" Margin="0,2">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="DELETE"
                                        Style="{StaticResource DangerButton}"
                                        FontSize="11"
                                        Padding="10,6"
                                        MinimumHeightRequest="32"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:CohortsViewModel}}, Path=DeleteCohortCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Attendance filter bar -->
            <Label Text="Attendance Records" Style="{StaticResource SectionHeader}"/>

            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10" Margin="0,0,0,8">
                <Label Grid.Column="0" Text="Filter:" VerticalOptions="Center" Style="{StaticResource MutedLabel}"/>
                <Picker Grid.Column="1"
                        ItemsSource="{Binding SessionFilterScopes}"
                        SelectedItem="{Binding SelectedSessionFilterScope}" />
                <DatePicker Grid.Column="2" Date="{Binding SelectedSessionDate}" />
                <Button Grid.Column="3"
                        Text="EXPORT CSV"
                        Command="{Binding ExportCsvCommand}"
                        Style="{StaticResource SecondaryButton}"
                        FontSize="12"
                        Padding="12,8" />
            </Grid>

            <Label Text="{Binding StatusMessage}" Style="{StaticResource MutedLabel}" Margin="0,0,0,8"/>

        </VerticalStackLayout>

        <!-- Attendance record list -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Students}" VerticalOptions="Fill">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Student">
                    <Border Style="{StaticResource Card}">
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="16" RowSpacing="4">

                            <StackLayout Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                <Label Text="{Binding Name}" FontFamily="OpenSansSemibold" FontSize="15" />
                                <Label Text="{Binding Surname}" FontSize="15" TextColor="{StaticResource TextSecondary}" />
                            </StackLayout>

                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding SignInTime, Converter={StaticResource SignInStatusConverter}}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="12"
                                   TextColor="{StaticResource AccentGreen}"
                                   VerticalOptions="Center" />

                            <StackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="16">
                                <Label Text="{Binding SignInTime, StringFormat='In: {0:HH:mm}'}" Style="{StaticResource MutedLabel}" />
                                <Label Text="{Binding SignOutTime, StringFormat='Out: {0:HH:mm}'}" Style="{StaticResource MutedLabel}" />
                            </StackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
