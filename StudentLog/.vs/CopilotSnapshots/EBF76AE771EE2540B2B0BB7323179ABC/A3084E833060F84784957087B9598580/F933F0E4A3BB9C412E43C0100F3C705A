<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:StudentLog.UI.ViewModels"
             xmlns:models="clr-namespace:StudentLog.Core.Models"
             xmlns:converters="clr-namespace:StudentLog.UI.Converters"
             x:Class="StudentLog.UI.Views.CohortsPage"
             x:DataType="viewModels:CohortsViewModel"
             Title="Cohorts">
    <ContentPage.Resources>
        <converters:SignInStatusConverter x:Key="SignInStatusConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <!-- Cohort Management Section -->
            <Label Text="Add New Cohort" FontAttributes="Bold" FontSize="16" />
            <Entry Placeholder="Cohort name" Text="{Binding NewCohortName}" />
            <Button Text="Add Cohort" Command="{Binding AddCohortCommand}" />

            <!-- Cohort Selection -->
            <Label Text="Select Cohort" FontAttributes="Bold" FontSize="16" Margin="0,16,0,0" />
            <CollectionView ItemsSource="{Binding Cohorts}" SelectionMode="Single" SelectedItem="{Binding SelectedCohort}" HeightRequest="150">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Cohort">
                        <Grid Padding="8" BackgroundColor="#f9f9f9" Margin="0,2">
                            <Label Text="{Binding Name}" FontSize="14" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Attendance Filter Section -->
            <Label Text="Attendance Records" FontAttributes="Bold" FontSize="16" Margin="0,16,0,0" />

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="0,0,0,8">
                <Label Grid.Column="0" Text="Filter:" VerticalOptions="Center" />
                <Picker Grid.Column="1"
                        ItemsSource="{Binding SessionFilterScopes}"
                        SelectedItem="{Binding SelectedSessionFilterScope}" />
            </Grid>

            <DatePicker Date="{Binding SelectedSessionDate}" />

            <Label Text="{Binding StatusMessage}" />

            <!-- Attendance View -->
            <CollectionView ItemsSource="{Binding Students}" HeightRequest="200">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Student">
                        <Grid Padding="12" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10" RowSpacing="5" BackgroundColor="#f0f0f0" Margin="0,4">
                            <StackLayout Grid.Row="0" Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding Name, StringFormat='{0}'}" FontAttributes="Bold" FontSize="16" />
                                <Label Text="{Binding Surname, StringFormat='{0}'}" FontSize="14" />
                            </StackLayout>

                            <StackLayout Grid.Row="0" Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                <Label Text="{Binding SignInTime, Converter={StaticResource SignInStatusConverter}}" FontAttributes="Bold" FontSize="14" />
                            </StackLayout>

                            <StackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="3" Margin="0,5,0,0">
                                <Label Text="{Binding SignInTime, StringFormat='Sign In: {0:yyyy-MM-dd HH:mm}'}" FontSize="12" TextColor="#666666" />
                                <Label Text="{Binding SignOutTime, StringFormat='Sign Out: {0:yyyy-MM-dd HH:mm}'}" FontSize="12" TextColor="#666666" />
                            </StackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
