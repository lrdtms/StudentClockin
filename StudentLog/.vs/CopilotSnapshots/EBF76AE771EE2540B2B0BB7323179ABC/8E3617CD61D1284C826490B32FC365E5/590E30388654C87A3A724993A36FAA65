<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:StudentLog.UI.ViewModels"
             xmlns:models="clr-namespace:StudentLog.Core.Models"
             xmlns:converters="clr-namespace:StudentLog.UI.Converters"
             x:Class="StudentLog.UI.Views.CohortsPage"
             x:DataType="viewModels:CohortsViewModel"
             Title="Cohorts">
    <ContentPage.Resources>
        <converters:SignInStatusConverter x:Key="SignInStatusConverter" />
    </ContentPage.Resources>
    <Grid Padding="16" RowDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,*" ColumnDefinitions="*">
        <Entry Grid.Row="0" Placeholder="Cohort name" Text="{Binding NewCohortName}" />
        <Button Grid.Row="1" Text="Add Cohort" Command="{Binding AddCohortCommand}" />

        <CollectionView Grid.Row="2" ItemsSource="{Binding Cohorts}" SelectionMode="Single" SelectedItem="{Binding SelectedCohort}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Cohort">
                    <Grid Padding="8">
                        <Label Text="{Binding Name}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="3" Text="Attendance sessions for selected cohort" />

        <Grid Grid.Row="4" ColumnDefinitions="Auto,*" ColumnSpacing="10">
            <Label Grid.Column="0" Text="Filter" VerticalOptions="Center" />
            <Picker Grid.Column="1"
                    ItemsSource="{Binding SessionFilterScopes}"
                    SelectedItem="{Binding SelectedSessionFilterScope}" />
        </Grid>

        <DatePicker Grid.Row="5" Date="{Binding SelectedSessionDate}" />

        <Label Grid.Row="6" Text="{Binding StatusMessage}" />

        <CollectionView Grid.Row="7" ItemsSource="{Binding Students}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Student">
                    <Grid Padding="8" ColumnDefinitions="*,*,Auto,Auto" ColumnSpacing="10">
                        <Label Grid.Column="0" Text="{Binding Name}" />
                        <Label Grid.Column="1" Text="{Binding Surname}" />
                        <Label Grid.Column="2" Text="{Binding SignInTime, StringFormat='In: {0:yyyy-MM-dd HH:mm}'}" />
                        <Label Grid.Column="3" Text="{Binding SignOutTime, StringFormat='Out: {0:yyyy-MM-dd HH:mm}'}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
