<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:StudentLog.UI.ViewModels"
             xmlns:models="clr-namespace:StudentLog.Core.Models"
             x:Class="StudentLog.UI.Views.StudentsPage"
             x:DataType="viewModels:StudentsViewModel"
             Title="Students">

    <AbsoluteLayout>
        <!-- Main Content with Scrolling -->
        <ScrollView AbsoluteLayout.LayoutBounds="0,0,1,1" AbsoluteLayout.LayoutFlags="All">
            <VerticalStackLayout Padding="16" Spacing="12">
                <!-- Add Student Section -->
                <Label Text="Add New Student" FontAttributes="Bold" FontSize="16" />

                <Picker Title="Select cohort"
                        ItemsSource="{Binding Cohorts}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedCohort}" />

                <Entry Placeholder="Name" Text="{Binding Name}" />
                <Entry Placeholder="Surname" Text="{Binding Surname}" />

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry Grid.Column="0" Placeholder="UID" Text="{Binding Uid}" />
                    <Button Grid.Column="1" Text="Scan UID" Command="{Binding ScanUidCommand}" />
                </Grid>

                <Button Text="Add Student" Command="{Binding AddStudentCommand}" />
                <Label Text="{Binding StatusMessage}" />

                <!-- Student Management Section -->
                <Label Text="Manage Students" FontAttributes="Bold" FontSize="16" Margin="0,16,0,0" />

                <!-- Student List -->
                <CollectionView ItemsSource="{Binding AllStudentsForCohort}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Student">
                            <Frame Padding="12" Margin="0,4" BackgroundColor="#e8f4f8" BorderColor="#4db8e8" CornerRadius="8">
                                <Grid Padding="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                    <!-- Student Info -->
                                    <StackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name, StringFormat='Name: {0}'}" FontSize="14" FontAttributes="Bold" />
                                        <Label Text="{Binding Surname, StringFormat='Surname: {0}'}" FontSize="13" />
                                        <Label Text="{Binding UID, StringFormat='UID: {0}'}" FontSize="12" TextColor="#666666" />
                                    </StackLayout>

                                    <!-- Edit Button -->
                                    <Button Grid.Column="1" 
                                            Text="Edit" 
                                            Padding="8" 
                                            FontSize="12"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditStudentCommand}"
                                            CommandParameter="{Binding .}" />

                                    <!-- Delete Button -->
                                    <Button Grid.Column="2" 
                                            Text="Delete" 
                                            Padding="8" 
                                            FontSize="12"
                                            BackgroundColor="#ff6b6b"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteStudentCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Edit Student Modal Overlay - Darkening Background -->
        <BoxView IsVisible="{Binding IsEditingStudent}" 
                 Color="Black" 
                 Opacity="0.5"
                 AbsoluteLayout.LayoutBounds="0,0,1,1"
                 AbsoluteLayout.LayoutFlags="All" />

        <!-- Edit Student Modal Frame -->
        <Frame IsVisible="{Binding IsEditingStudent}" 
               Padding="20" 
               CornerRadius="10"
               BackgroundColor="White"
               BorderColor="#4db8e8"
               AbsoluteLayout.LayoutBounds="0.1,0.3,0.8,0.4"
               AbsoluteLayout.LayoutFlags="None">
            <VerticalStackLayout Spacing="12">
                <Label Text="Edit Student" FontAttributes="Bold" FontSize="18" />

                <Entry Placeholder="Name" Text="{Binding EditStudentName}" />
                <Entry Placeholder="Surname" Text="{Binding EditStudentSurname}" />
                <Entry Placeholder="UID" Text="{Binding EditStudentUid}" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
                    <Button Grid.Column="0" Text="Save" BackgroundColor="#51c400" Command="{Binding SaveEditedStudentCommand}" />
                    <Button Grid.Column="1" Text="Cancel" BackgroundColor="#cccccc" Command="{Binding CancelEditCommand}" />
                </Grid>
            </VerticalStackLayout>
        </Frame>
    </AbsoluteLayout>
</ContentPage>
