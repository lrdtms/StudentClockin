<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:StudentLog.UI.ViewModels"
             xmlns:models="clr-namespace:StudentLog.Core.Models"
             xmlns:converters="clr-namespace:StudentLog.UI.Converters"
             x:Class="StudentLog.UI.Views.CohortsPage"
             x:DataType="viewModels:CohortsViewModel"
             Title="Cohorts">
    <ContentPage.Resources>
        <converters:SignInStatusConverter x:Key="SignInStatusConverter" />
    </ContentPage.Resources>
    <Grid Padding="16" RowDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,*" ColumnDefinitions="*">
        <Entry Grid.Row="0" Placeholder="Cohort name" Text="{Binding NewCohortName}" />
        <Button Grid.Row="1" Text="Add Cohort" Command="{Binding AddCohortCommand}" />

        <CollectionView Grid.Row="2" ItemsSource="{Binding Cohorts}" SelectionMode="Single" SelectedItem="{Binding SelectedCohort}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Cohort">
                    <Grid Padding="8">
                        <Label Text="{Binding Name}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="3" Text="Attendance sessions for selected cohort" />

        <Grid Grid.Row="4" ColumnDefinitions="Auto,*" ColumnSpacing="10">
            <Label Grid.Column="0" Text="Filter" VerticalOptions="Center" />
            <Picker Grid.Column="1"
                    ItemsSource="{Binding SessionFilterScopes}"
                    SelectedItem="{Binding SelectedSessionFilterScope}" />
        </Grid>

        <DatePicker Grid.Row="5" Date="{Binding SelectedSessionDate}" />

        <Label Grid.Row="6" Text="{Binding StatusMessage}" />

        <CollectionView Grid.Row="7" ItemsSource="{Binding Students}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Student">
                    <Grid Padding="12" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10" RowSpacing="5" BackgroundColor="#f0f0f0" Margin="0,4">
                        <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name, StringFormat='{0}'}" FontAttributes="Bold" FontSize="16" />
                        <Label Grid.Row="0" Grid.Column="0" Text="{Binding Surname, StringFormat='{0}'}" FontAttributes="Bold" FontSize="16" Margin="0,0,0,0" />

                        <StackLayout Grid.Row="0" Grid.Column="1" Spacing="5" VerticalOptions="Center">
                            <Label Text="{Binding SignInTime, Converter={StaticResource SignInStatusConverter}}" FontAttributes="Bold" FontSize="14" />
                        </StackLayout>

                        <StackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="3" Margin="0,5,0,0">
                            <Label Text="{Binding SignInTime, StringFormat='Sign In: {0:yyyy-MM-dd HH:mm}'}" FontSize="12" TextColor="#666666" />
                            <Label Text="{Binding SignOutTime, StringFormat='Sign Out: {0:yyyy-MM-dd HH:mm}'}" FontSize="12" TextColor="#666666" />
                        </StackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
