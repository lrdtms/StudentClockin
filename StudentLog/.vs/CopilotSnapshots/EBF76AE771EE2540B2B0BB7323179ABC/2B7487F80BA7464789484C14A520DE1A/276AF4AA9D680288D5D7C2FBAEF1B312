<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:StudentLog.UI.ViewModels"
             x:Class="StudentLog.UI.Views.StudentsPage"
             x:DataType="viewModels:StudentsViewModel"
             Title="Students">
    <Grid Padding="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*">
        <Picker Grid.Row="0"
                Title="Select cohort"
                ItemsSource="{Binding Cohorts}"
                ItemDisplayBinding="{Binding Name}"
                SelectedItem="{Binding SelectedCohort}" />

        <Entry Grid.Row="1" Placeholder="Name" Text="{Binding Name}" />
        <Entry Grid.Row="2" Placeholder="Surname" Text="{Binding Surname}" />

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry Grid.Column="0" Placeholder="UID" Text="{Binding Uid}" />
            <Button Grid.Column="1" Text="Scan UID" Command="{Binding ScanUidCommand}" />
        </Grid>

        <Button Grid.Row="4" Text="Add Student" Command="{Binding AddStudentCommand}" />
        <Label Grid.Row="5" Text="{Binding StatusMessage}" />
    </Grid>
</ContentPage>
