<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:StudentLog.UI.ViewModels"
             xmlns:models="clr-namespace:StudentLog.Core.Models"
             xmlns:converters="clr-namespace:StudentLog.UI.Converters"
             x:Class="StudentLog.UI.Views.CohortsPage"
             x:DataType="viewModels:CohortsViewModel"
             Title="Cohorts">
    <ContentPage.Resources>
        <converters:SignInStatusConverter x:Key="SignInStatusConverter" />
    </ContentPage.Resources>

    <AbsoluteLayout>
        <!-- Main Content -->
        <ScrollView AbsoluteLayout.LayoutBounds="0,0,1,1" AbsoluteLayout.LayoutFlags="All">
            <Grid Padding="16" RowDefinitions="Auto,Auto,200,Auto,Auto,Auto,Auto,200,Auto,*" ColumnDefinitions="*">
                <!-- Top Section: Cohort Management -->
                <Entry Grid.Row="0" Placeholder="Cohort name" Text="{Binding NewCohortName}" />
                <Button Grid.Row="1" Text="Add Cohort" Command="{Binding AddCohortCommand}" />

                <!-- Cohort Selection -->
                <CollectionView Grid.Row="2" ItemsSource="{Binding Cohorts}" SelectionMode="Single" SelectedItem="{Binding SelectedCohort}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Cohort">
                            <Grid Padding="8">
                                <Label Text="{Binding Name}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Attendance Filter Section -->
                <Label Grid.Row="3" Text="Attendance sessions for selected cohort" FontAttributes="Bold" />

                <Grid Grid.Row="4" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Grid.Column="0" Text="Filter" VerticalOptions="Center" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding SessionFilterScopes}"
                            SelectedItem="{Binding SelectedSessionFilterScope}" />
                </Grid>

                <DatePicker Grid.Row="5" Date="{Binding SelectedSessionDate}" />

                <Label Grid.Row="6" Text="{Binding StatusMessage}" />

                <!-- Attendance View -->
                <CollectionView Grid.Row="7" ItemsSource="{Binding Students}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Student">
                            <Grid Padding="12" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10" RowSpacing="5" BackgroundColor="#f0f0f0" Margin="0,4">
                                <StackLayout Grid.Row="0" Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Name, StringFormat='{0}'}" FontAttributes="Bold" FontSize="16" />
                                    <Label Text="{Binding Surname, StringFormat='{0}'}" FontSize="14" />
                                </StackLayout>

                                <StackLayout Grid.Row="0" Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                    <Label Text="{Binding SignInTime, Converter={StaticResource SignInStatusConverter}}" FontAttributes="Bold" FontSize="14" />
                                </StackLayout>

                                <StackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="3" Margin="0,5,0,0">
                                    <Label Text="{Binding SignInTime, StringFormat='Sign In: {0:yyyy-MM-dd HH:mm}'}" FontSize="12" TextColor="#666666" />
                                    <Label Text="{Binding SignOutTime, StringFormat='Sign Out: {0:yyyy-MM-dd HH:mm}'}" FontSize="12" TextColor="#666666" />
                                </StackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Student Management Section -->
                <Label Grid.Row="8" Text="Manage Students" FontAttributes="Bold" />

                <!-- Student List -->
                <CollectionView Grid.Row="9" ItemsSource="{Binding AllStudentsForCohort}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Student">
                            <Frame Padding="8" Margin="0,4" BackgroundColor="#e8f4f8" BorderColor="#4db8e8">
                                <Grid Padding="8" RowDefinitions="Auto" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                    <!-- Student Info -->
                                    <StackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name, StringFormat='Name: {0}'}" FontSize="14" FontAttributes="Bold" />
                                        <Label Text="{Binding Surname, StringFormat='Surname: {0}'}" FontSize="13" />
                                        <Label Text="{Binding UID, StringFormat='UID: {0}'}" FontSize="12" TextColor="#666666" />
                                    </StackLayout>

                                    <!-- Edit Button -->
                                    <Button Grid.Column="1" 
                                            Text="Edit" 
                                            Padding="8" 
                                            FontSize="12"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditStudentCommand}"
                                            CommandParameter="{Binding .}" />

                                    <!-- Delete Button -->
                                    <Button Grid.Column="2" 
                                            Text="Delete" 
                                            Padding="8" 
                                            FontSize="12"
                                            BackgroundColor="#ff6b6b"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteStudentCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </ScrollView>

        <!-- Edit Student Modal Overlay -->
        <Frame IsVisible="{Binding IsEditingStudent}" 
               Padding="20" 
               CornerRadius="10"
               BackgroundColor="White"
               BorderColor="#4db8e8"
               AbsoluteLayout.LayoutBounds="0.1,0.3,0.8,0.4"
               AbsoluteLayout.LayoutFlags="None">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*">
                <Label Grid.Row="0" Text="Edit Student" FontAttributes="Bold" FontSize="18" Margin="0,0,0,16" />

                <Entry Grid.Row="1" Placeholder="Name" Text="{Binding EditStudentName}" Margin="0,0,0,8" />
                <Entry Grid.Row="2" Placeholder="Surname" Text="{Binding EditStudentSurname}" Margin="0,0,0,8" />
                <Entry Grid.Row="3" Placeholder="UID" Text="{Binding EditStudentUid}" Margin="0,0,0,16" />

                <Grid Grid.Row="5" ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0" Text="Save" BackgroundColor="#51c400" Command="{Binding SaveEditedStudentCommand}" />
                    <Button Grid.Column="1" Text="Cancel" BackgroundColor="#cccccc" Command="{Binding CancelEditCommand}" />
                </Grid>
            </Grid>
        </Frame>

        <!-- Darkening Overlay when editing -->
        <BoxView IsVisible="{Binding IsEditingStudent}" 
                 Color="Black" 
                 Opacity="0.5"
                 AbsoluteLayout.LayoutBounds="0,0,1,1"
                 AbsoluteLayout.LayoutFlags="All" />
    </AbsoluteLayout>
</ContentPage>
