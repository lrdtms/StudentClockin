using StudentLog.Application.Interfaces;
using Windows.Devices.Enumeration;
using Windows.Devices.SmartCards;
using Windows.Security.Cryptography;
using Windows.Storage.Streams;

namespace StudentLog.Infrastructure.Services;

public class NfcService : INfcService
{
    private const int DefaultScanTimeoutSeconds = 10;
    private CancellationTokenSource? _listeningCts;

    public bool IsListening { get; private set; }

    public Task StartListeningAsync(Func<string, Task> onUidScanned, CancellationToken cancellationToken = default)
    {
        System.Diagnostics.Debug.WriteLine($"[NFC] StartListeningAsync called");
        _listeningCts?.Cancel();
        _listeningCts = CancellationTokenSource.CreateLinkedTokenSource(cancellationToken);
        IsListening = true;

        _ = Task.Run(async () =>
        {
            System.Diagnostics.Debug.WriteLine($"[NFC] Listening thread started");
            string? lastUid = null;
            int failureCount = 0;

            while (!_listeningCts.IsCancellationRequested)
            {
                try
                {
                    // Use much longer timeout for initial reader operations (5 seconds per attempt)
                    var uid = await TryReadUidFromAcr122uAsync(TimeSpan.FromSeconds(5), _listeningCts.Token);
                    failureCount = 0; // Reset failure counter on success

                    if (!string.IsNullOrWhiteSpace(uid))
                    {
                        System.Diagnostics.Debug.WriteLine($"[NFC] Card detected - UID: {uid}, LastUID: {lastUid}, IsDuplicate: {uid == lastUid}");
                        if (uid != lastUid)
                        {
                            System.Diagnostics.Debug.WriteLine($"[NFC] New card detected, calling onUidScanned callback");
                            lastUid = uid;
                            await onUidScanned(uid);
                        }
                        else
                        {
                            System.Diagnostics.Debug.WriteLine($"[NFC] Duplicate card detected, skipping callback");
                        }
                    }
                }
                catch (OperationCanceledException)
                {
                    System.Diagnostics.Debug.WriteLine($"[NFC] Listening cancelled");
                    break;
                }
                catch (Exception ex)
                {
                    failureCount++;
                    System.Diagnostics.Debug.WriteLine($"[NFC] Error during scan (attempt {failureCount}): {ex.GetType().Name} - {ex.Message}");

                    // Stop after 5 consecutive failures
                    if (failureCount >= 5)
                    {
                        System.Diagnostics.Debug.WriteLine($"[NFC] Too many consecutive failures, stopping listener");
                        break;
                    }

                    // Keep listener alive; hardware/service can be transient.
                    await Task.Delay(500, _listeningCts.Token);
                }
            }
            System.Diagnostics.Debug.WriteLine($"[NFC] Listening thread ended");
        }, _listeningCts.Token);

        return Task.CompletedTask;
    }

    public Task StopListeningAsync(CancellationToken cancellationToken = default)
    {
        System.Diagnostics.Debug.WriteLine($"[NFC] StopListeningAsync called");
        _listeningCts?.Cancel();
        _listeningCts = null;
        IsListening = false;
        return Task.CompletedTask;
    }

    public async Task<string?> ScanSingleUidAsync(CancellationToken cancellationToken = default)
    {
        IsListening = true;
        try
        {
            var uid = await TryReadUidFromAcr122uAsync(TimeSpan.FromSeconds(DefaultScanTimeoutSeconds), cancellationToken);
            if (!string.IsNullOrWhiteSpace(uid))
            {
                return uid;
            }

            var manualUid = await MainThread.InvokeOnMainThreadAsync(async () =>
                await Microsoft.Maui.Controls.Application.Current!.Windows[0].Page!.DisplayPromptAsync(
                    "Scan NFC",
                    "No UID was detected from ACR122U. Scan again or enter UID manually.",
                    "Save",
                    "Cancel",
                    "UID"));

            return string.IsNullOrWhiteSpace(manualUid) ? null : manualUid.Trim();
        }
        finally
        {
            IsListening = false;
        }
    }

    private static async Task<string?> TryReadUidFromAcr122uAsync(TimeSpan timeout, CancellationToken cancellationToken)
    {
        try
        {
            using var timeoutCts = CancellationTokenSource.CreateLinkedTokenSource(cancellationToken);
            timeoutCts.CancelAfter(timeout);
            var ct = timeoutCts.Token;

            System.Diagnostics.Debug.WriteLine($"[NFC] TryReadUidFromAcr122uAsync: Looking for smart card readers...");
            var selector = SmartCardReader.GetDeviceSelector();
            var devices = await DeviceInformation.FindAllAsync(selector);
            System.Diagnostics.Debug.WriteLine($"[NFC] Found {devices.Count} smart card devices");

            var readers = new List<SmartCardReader>();
            foreach (var device in devices)
            {
                var reader = await SmartCardReader.FromIdAsync(device.Id);
                if (reader is not null)
                {
                    System.Diagnostics.Debug.WriteLine($"[NFC] Found reader: {reader.Name}");
                    readers.Add(reader);
                }
            }

            var targetReader = readers.FirstOrDefault(r =>
                r.Name.Contains("ACR122", StringComparison.OrdinalIgnoreCase) ||
                r.Name.Contains("ACS", StringComparison.OrdinalIgnoreCase));

            if (targetReader is null)
            {
                System.Diagnostics.Debug.WriteLine($"[NFC] No ACR122U/ACS reader found. Available readers: {string.Join(", ", readers.Select(r => r.Name))}");
                return null;
            }

            System.Diagnostics.Debug.WriteLine($"[NFC] Using reader: {targetReader.Name}");

            while (!ct.IsCancellationRequested)
            {
                try
                {
                    var cards = await targetReader.FindAllCardsAsync();
                    if (cards.Count > 0)
                    {
                        System.Diagnostics.Debug.WriteLine($"[NFC] {cards.Count} card(s) detected");
                        var card = cards[0];
                        using var connection = await card.ConnectAsync();

                        var command = new byte[] { 0xFF, 0xCA, 0x00, 0x00, 0x00 };
                        var requestBuffer = CryptographicBuffer.CreateFromByteArray(command);
                        var response = await connection.TransmitAsync(requestBuffer);
                        CryptographicBuffer.CopyToByteArray(response, out var responseBytes);

                        if (responseBytes.Length >= 2)
                        {
                            var sw1 = responseBytes[^2];
                            var sw2 = responseBytes[^1];
                            if (sw1 == 0x90 && sw2 == 0x00 && responseBytes.Length > 2)
                            {
                                var uidBytes = responseBytes[..^2];
                                var uid = Convert.ToHexString(uidBytes);
                                System.Diagnostics.Debug.WriteLine($"[NFC] ✓ UID extracted: {uid}");
                                return uid;
                            }
                        }
                    }
                }
                catch (Exception ex)
                {
                    System.Diagnostics.Debug.WriteLine($"[NFC] Error reading card: {ex.GetType().Name} - {ex.Message}");
                }

                await Task.Delay(200, ct);
            }

            System.Diagnostics.Debug.WriteLine($"[NFC] Timeout waiting for card");
            return null;
        }
        catch (OperationCanceledException)
        {
            System.Diagnostics.Debug.WriteLine($"[NFC] TryReadUidFromAcr122uAsync cancelled");
            throw;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[NFC] TryReadUidFromAcr122uAsync error: {ex.GetType().Name} - {ex.Message}");
            return null;
        }
    }
}
