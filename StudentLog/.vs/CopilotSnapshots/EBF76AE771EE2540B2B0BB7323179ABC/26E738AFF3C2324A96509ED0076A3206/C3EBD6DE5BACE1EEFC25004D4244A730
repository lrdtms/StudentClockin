<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:StudentLog.UI.ViewModels"
             x:Class="StudentLog.UI.Views.CheckInSessionPage"
             x:DataType="viewModels:CheckInSessionViewModel"
             Title="Check-In Sessions">
    <Grid Padding="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" ColumnDefinitions="*">
        <Label Grid.Row="0" Text="Cohort" />
        <Picker Grid.Row="1"
                Title="Select cohort"
                ItemsSource="{Binding Cohorts}"
                ItemDisplayBinding="{Binding Name}"
                SelectedItem="{Binding SelectedCohort}" />

        <Label Grid.Row="2" Text="Session Type" />
        <Picker Grid.Row="3"
                Title="Select session"
                SelectedIndex="0"
                ItemsSource="{Binding SessionTypes}"
                SelectedItem="{Binding SelectedSessionType}" />

        <DatePicker Grid.Row="4" Date="{Binding SelectedDate}" />

        <Grid Grid.Row="5" ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Grid.Column="0" Text="Start Session" Command="{Binding StartSessionCommand}" />
            <Button Grid.Column="1" Text="Stop Session" Command="{Binding StopSessionCommand}" />
        </Grid>

        <Label Grid.Row="6" Text="{Binding StatusMessage}" />
    </Grid>
</ContentPage>
