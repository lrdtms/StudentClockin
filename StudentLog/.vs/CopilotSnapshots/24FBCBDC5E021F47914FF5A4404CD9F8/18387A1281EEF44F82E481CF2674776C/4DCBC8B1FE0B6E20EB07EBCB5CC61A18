<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StudentLog.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:StudentLog.UI.Views"
    Title="StudentLog">

    <FlyoutItem Title="Check-In Sessions" Route="CheckInSessionPage">
        <ShellContent ContentTemplate="{DataTemplate views:CheckInSessionPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Cohorts" Route="CohortsPage">
        <ShellContent ContentTemplate="{DataTemplate views:CohortsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Students" Route="StudentsPage">
        <ShellContent ContentTemplate="{DataTemplate views:StudentsPage}" />
    </FlyoutItem>

</Shell>
